{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Start Backend Server",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/server.js"
        },
        {
            "name": "Launch Frontend in Browser",
            "request": "launch",
            "type": "msedge",
            "file": "${workspaceFolder}/index.html"
        }
    ]
}
